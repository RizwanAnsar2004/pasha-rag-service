# Copy to .env and fill in values. Put your REAL key only in .env (gitignored),
# never in this example file.

# Required for answer generation + embeddings (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Optional: gate the service's own endpoints. Leave empty to disable auth.
SERVICE_API_KEY=

# Generation
GENERATION_MODEL=gpt-5.4-mini
MAX_TOKENS=1024

# Embeddings (OpenAI embedding model). 3-large (3072 dims) retrieves proper
# nouns and acronyms — names, P@SHA, ITeS — noticeably better than 3-small.
# Changing this invalidates the whole collection: Chroma fixes the dimension at
# creation, so a switch means dropping data/chroma, re-embedding everything, and
# retuning MAX_DISTANCE (distance distributions differ per model).
EMBEDDING_MODEL=text-embedding-3-large

# Vector store
CHROMA_PATH=./data/chroma
COLLECTION_NAME=documents

# Supabase — source of truth for the Pasha databank sync (service role key,
# bypasses RLS). Required for `python -m scripts.sync_databank` and the
# /databank/event + /databank/sync endpoints.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Rate limiting on /query. The quota is keyed on the caller's `session_id`
# (sent in the request body), so one visitor's conversation is counted on its
# own. QUERY_IP_RATE_LIMIT is the backstop that stops someone minting a fresh
# session id per question — keep it well above the session limit, since an
# office or mobile network can put many real people behind one address.
# Several limits can be combined with `;`.
#
# NOTE: 5/minute is an anti-hammering limit, not a spend cap — it permits 300
# questions an hour from one visitor, each of which is a paid embedding +
# generation call. The hourly half of the IP limit is what actually bounds the
# bill; add an hourly window here too (e.g. `5/minute;60/hour`) if you want a
# per-visitor ceiling as well.
QUERY_RATE_LIMIT=5/minute
QUERY_IP_RATE_LIMIT=60/minute;500/hour

# Retrieval / guardrails
TOP_K=8
# Cosine distance threshold (0=identical, 2=opposite). Above this -> refuse.
# Calibrated for text-embedding-3-large; re-measure if you change the model.
MAX_DISTANCE=0.60
