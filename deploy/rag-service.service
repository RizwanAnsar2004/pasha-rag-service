[Unit]
Description=PASHA RAG Service (FastAPI + ChromaDB) 8000
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Adjust to the user/paths on your server.
User=rag
Group=rag
WorkingDirectory=/opt/rag-service

# Loads OPENAI_API_KEY, SERVICE_API_KEY, etc. (KEY=value lines, no `export`).
EnvironmentFile=/opt/rag-service/.env

# Use the venv's interpreter. 2 workers is a sane default; tune to your CPU.
ExecStart=/opt/rag-service/.venv/bin/python -m uvicorn app.main:app \
    --host 0.0.0.0 --port 8000 --workers 2

Restart=on-failure
RestartSec=3

# Light hardening.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
